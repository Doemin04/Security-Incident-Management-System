# CORS — set this to the exact origin your frontend runs on.
# Only this origin will be allowed to make requests to the API.
# Example: http://localhost:5500  (VS Code Live Server)
#          http://localhost:5173  (Vite)
#          http://localhost:3001  (React CRA)
FRONTEND_ORIGIN=http://localhost:YOUR_PORT_HERE
